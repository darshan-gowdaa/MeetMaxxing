# ─── Backend — backend/.env.example ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project → Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local default — update for production (e.g. Redis Cloud, Upstash)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── Qdrant ────────────────────────────────────────────────────────────────────
# Local default — update for Qdrant Cloud
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=<your-qdrant-api-key>

# ── Google / Gemini ───────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ── LLM Fallback Providers ───────────────────────────────────────────────────
# Optional — used as fallback when Gemini quota is exceeded
GROQ_API_KEY=<your-groq-api-key>
OPEN_ROUTER_API_KEY=<your-openrouter-api-key>
PERPLEXITY_API_KEY=<your-perplexity-api-key>

# ── Google Calendar OAuth2 ───────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<your-google-oauth-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/callback

# ── Lyzr Guardrails ───────────────────────────────────────────────────────────
# Get from: https://studio.lyzr.ai
LYZR_API_KEY=<your-lyzr-api-key>

# ── App ───────────────────────────────────────────────────────────────────────
APP_SECRET_KEY=<random-secret-at-least-32-chars>
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development


# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=15
RATE_LIMIT_BURST=5

# ── Realtime Agent ────────────────────────────────────────────────────────────
REALTIME_WINDOW_MINUTES=5
REALTIME_CADENCE_SECONDS=20
