# Required
SUPABASE_URL=https://<SUPABASE_URL>
SUPABASE_ANON_KEY=***REDACTED_SUPABASE_ANON_KEY***
SUPABASE_SERVICE_ROLE_KEY=***REDACTED_SUPABASE_SERVICE_ROLE***

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=***REDACTED_QDRANT_API_KEY***

# Google / Gemini
GEMINI_API_KEY=***REDACTED_GEMINI_API_KEY***
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

GROQ_API_KEY=***REDACTED_GROQ_API_KEY***
OPEN_ROUTER_API_KEY=***REDACTED_OPENROUTER_KEY***
PERPLEXITY_API_KEY=***REDACTED_PERPLEXITY_KEY***

# Google Calendar OAuth2
GOOGLE_CLIENT_ID=***REDACTED_GOOGLE_CLIENT_ID***
GOOGLE_CLIENT_SECRET=***REDACTED_GOOGLE_CLIENT_SECRET***
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/callback

# Lyzr
LYZR_API_KEY=***REDACTED_LYZR_KEY***

# App
APP_SECRET_KEY=***REDACTED_APP_SECRET***
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development

# Slack Integrations
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Rate Limiting Settings
RATE_LIMIT_RPM=15
RATE_LIMIT_BURST=5

# Realtime agent settings
REALTIME_WINDOW_MINUTES=5
REALTIME_CADENCE_SECONDS=20
